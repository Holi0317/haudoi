{
  "name": "@haudoi/worker",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc -noEmit",
    "test": "vitest",
    "build-client": "tsdown --dts src/client/index.ts -d src/client/build/"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client/build/index.d.mts",
      "default": "./src/client/build/index.mjs"
    }
  },
  "dependencies": {
    "@haudoi/dsl": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "@std/csv": "jsr:^1.0.6",
    "@std/html": "jsr:^1.0.6",
    "@truto/sqlite-builder": "^1.0.4",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.46.1",
    "hono": "^4.12.22",
    "ky": "^2.0.2",
    "p-limit": "^7.3.0",
    "uint8array-extras": "^1.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "msw": "^2.14.6",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}
